{
  "name": "unigrok-project-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "build": "bash scripts/build-verified.sh",
    "build:standalone": "bash scripts/build-standalone.sh",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run check:deployment && npm run typecheck && npm run build && npm run test:unit",
    "test:deployment": "npm run check:deployment && npm run typecheck && npm run build && npm run test:unit",
    "test:unit": "node --import tsx --test tests/*.test.mjs tests/*.test.ts",
    "check:source": "node scripts/check-template-safety.mjs --allow-provisioned-manifest",
    "check:deployment": "node scripts/check-template-safety.mjs --allow-provisioned-manifest",
    "typecheck": "tsc --noEmit",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "@octokit/auth-app": "8.2.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.7",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.2.1",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "type": "module",
  "displayName": "UniGrok Project Site"
}
