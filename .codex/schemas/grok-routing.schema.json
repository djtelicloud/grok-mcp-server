{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/uni-grok-mcp/grok-routing.schema.json",
  "title": "Codex Grok MCP Routing",
  "type": "object",
  "required": [
    "schema_version",
    "purpose",
    "server",
    "routes",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "server": {
      "const": "grok"
    },
    "routes": {
      "type": "array",
      "minItems": 1
    }
  }
}

