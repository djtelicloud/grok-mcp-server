{
  "$schema": "../schemas/threads-registry.schema.json",
  "schema_version": 1,
  "thread_namespace": "codex/uni-grok-mcp",
  "default_environment": "worktree",
  "archetypes": [
    {
      "id": "ci-triage",
      "title_template": "UniGrok CI triage: {short_task}",
      "environment": "worktree",
      "initial_prompt_ref": "./templates/ci-triage.md",
      "default_thinking": "high",
      "pinned_default": false,
      "archive_policy": "archive_when_summary_delivered",
      "codex_app_functions": [
        "list_projects",
        "create_thread",
        "read_thread",
        "send_message_to_thread",
        "set_thread_title",
        "set_thread_archived"
      ],
      "handoff_to": "human"
    },
    {
      "id": "grok-review",
      "title_template": "UniGrok Grok review: {short_task}",
      "environment": "worktree",
      "initial_prompt_ref": "./templates/grok-review.md",
      "default_thinking": "high",
      "pinned_default": false,
      "archive_policy": "archive_after_findings_addressed",
      "codex_app_functions": [
        "list_projects",
        "create_thread",
        "read_thread",
        "send_message_to_thread",
        "handoff_thread",
        "get_handoff_status"
      ],
      "handoff_to": "human"
    },
    {
      "id": "mcp-contract-audit",
      "title_template": "UniGrok MCP contract audit: {short_task}",
      "environment": "worktree",
      "initial_prompt_ref": "./templates/mcp-audit.md",
      "default_thinking": "xhigh",
      "pinned_default": true,
      "archive_policy": "keep_until_user_archives",
      "codex_app_functions": [
        "list_projects",
        "create_thread",
        "fork_thread",
        "read_thread",
        "set_thread_pinned"
      ],
      "handoff_to": "human"
    },
    {
      "id": "dependency-review",
      "title_template": "UniGrok dependency review: {short_task}",
      "environment": "worktree",
      "initial_prompt_ref": "./templates/dependency-review.md",
      "default_thinking": "medium",
      "pinned_default": false,
      "archive_policy": "archive_when_pr_or_patch_ready",
      "codex_app_functions": [
        "list_projects",
        "create_thread",
        "read_thread",
        "set_thread_title",
        "set_thread_archived"
      ],
      "handoff_to": "human"
    },
    {
      "id": "release-verification",
      "title_template": "UniGrok release verification: {short_task}",
      "environment": "worktree",
      "initial_prompt_ref": "./templates/release-verification.md",
      "default_thinking": "high",
      "pinned_default": true,
      "archive_policy": "keep_until_release_complete",
      "codex_app_functions": [
        "list_projects",
        "create_thread",
        "send_message_to_thread",
        "read_thread",
        "handoff_thread",
        "get_handoff_status",
        "set_thread_pinned"
      ],
      "handoff_to": "human"
    }
  ]
}
