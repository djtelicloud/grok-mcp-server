# Local MCP port. The checked-in Compose definition runs one local instance at a time.
UNIGROK_PORT=4765

# Shared public harness controls (values outside each range are clamped).
# Provider deadlines: 30-600 seconds.
UNIGROK_BUILD_TIMEOUT=120
UNIGROK_API_TIMEOUT=120
# Long-running autonomy + mission v2. Docker compose defaults these on for live.
UNIGROK_AUTONOMY=true
UNIGROK_MISSION_V2=true
UNIGROK_MISSION_ENVELOPE_VERSION=1
# Mission lease/heartbeat window: 30-900 seconds.
UNIGROK_MISSION_LEASE_TTL=180
# A0′/A0: task-class assign + literal exact-match CommitDone.
UNIGROK_TASK_CLASS=true
UNIGROK_VERIFY_LITERAL=true
# Per-turn context pack prune + prefrontal condenser (off|cpu|hive).
# cpu: inventory → persona votes → lead merge → ≤2 PFC loops → pfc_absent foresight.
# Docker live default: cpu.
UNIGROK_CONTEXT_PACK=cpu
# Detached initial agent wait: 1-60 seconds. Polling agent_result is separately
# bounded to 1-20 seconds per call.
UNIGROK_AGENT_SYNC_WINDOW=16
# Provider tool-loop ceiling per turn: 1-24. A frozen mission governor may use less.
UNIGROK_AGENT_MAX_TURNS=6
# Semantic API router fallback: 64-1024 output tokens. CLI-first route votes use
# UNIGROK_VOTE_MAX_OUTPUT (48-512) instead.
UNIGROK_ROUTER_MAX_OUTPUT_TOKENS=256
UNIGROK_VOTE_MAX_OUTPUT=128
# Terminal runtime rows: 1-720 hours. Named sessions and remembered facts remain
# until explicitly deleted.
UNIGROK_STATE_RETENTION_HOURS=24
# Task and workspace couriers: 1024-500000 characters each.
UNIGROK_MAX_PROMPT_CHARS=100000
UNIGROK_MAX_WORKSPACE_CONTEXT_CHARS=100000
# Cap concurrent xAI SDK worker threads for metered generation/mutations (1-16).
# UNIGROK_API_MAX_INFLIGHT=4
# Separate smaller pool for file/catalog reads so slow list_files cannot HOL-block
# generation (B1): 1-4.
# UNIGROK_API_MAX_FILE_INFLIGHT=2
# Slow file/media deadlines (native SDK timeout is 2s under these await budgets).
# list: 60-600 seconds; I/O: 30-600; media: 60-600.
# UNIGROK_FILE_LIST_TIMEOUT=120
# UNIGROK_FILE_IO_TIMEOUT=60
# UNIGROK_MEDIA_TIMEOUT=300
# xai_get_file_content cap: 1024-10000000 bytes, checked before download when
# metadata exposes size and enforced by a bounded read when streaming is available.
# UNIGROK_FILE_CONTENT_MAX_BYTES=2000000
# Model-catalog cache: 5-600 seconds.
UNIGROK_CATALOG_TTL=60
UNIGROK_ENABLE_METERED_API=true

# Optional API default. When unset, UniGrok uses the first model returned by the live
# xAI language-model catalog. This is a preference, never a model allowlist.
# UNIGROK_API_MODEL=

# Optional metered xAI developer API plane. Keep this only in the server's ignored
# .env file; never add it to IDE MCP JSON.
# XAI_API_KEY=


# The Docker service creates a persistent OAuth volume and uses this in-container path.
UNIGROK_AUTH_PATH=/home/appuser/.grok/auth.json
