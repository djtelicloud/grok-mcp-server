# Template only — copy to .env and fill in real values.
# This file is never loaded by the server; the placeholder key below is
# rejected at startup.
XAI_API_KEY=your_xai_api_key_here

# Gateway runtime: local, http, or cloudrun
UNIGROK_RUNTIME=local

# Host-facing Docker ports. 4765 spells GROK; 4766 is the contributor Forge.
# Containers still listen internally on 8080.
UNIGROK_PORT=4765
UNIGROK_DEV_PORT=4766

# Comma-separated client bearer tokens for every non-public remote route,
# including /mcp, /v1, /runtimez, /metrics, /ui, and /docs.
# A Cloud Run deployment requires either these static keys or the OAuth
# introspection boundary below. Private production MCP uses OAuth.
UNIGROK_API_KEYS=

# Local developer escape hatch only. It bypasses configured client tokens only
# when the listener, Host, and ASGI peer are all loopback; the trusted Docker
# proxy declaration does not activate this broad bypass. Cloud Run rejects it,
# and it never permits an unauthenticated non-loopback bind.
UNIGROK_ALLOW_UNAUTHENTICATED=0

# OAuth 2.1 resource-server discovery and live token introspection. Production
# private MCP sets all four values; local installations normally leave them
# blank and use the loopback boundary or static client keys.
UNIGROK_PUBLIC_MCP_URL=
UNIGROK_OAUTH_AUTHORIZATION_SERVERS=
UNIGROK_OAUTH_SCOPES=unigrok:connect,unigrok:invoke,unigrok:review,unigrok:chat,unigrok:status
UNIGROK_OAUTH_INTROSPECTION_URL=

# Optional state root. Cloud Run defaults to /tmp/uni-grok.
UNIGROK_STATE_DIR=

# Service/workspace boundary. Docker Compose sets stable mode automatically.
# Only UniGrok source contributors should enable contributor mode; it attaches
# the source checkout and unlocks repository-specific file/git/memory flows.
UNIGROK_SERVICE_MODE=
UNIGROK_CONTRIBUTOR_MODE=0
WORKSPACE_ROOT=

# Optional phoneword mode dials. Use docker-compose.dials.yml to publish them;
# the overlay sets UNIGROK_MODE_DIALS=1 inside the stable container.
UNIGROK_MODE_DIALS=0
UNIGROK_AUTO_PORT=2886
UNIGROK_FAST_PORT=3278
UNIGROK_REASON_PORT=7327
UNIGROK_THINK_PORT=8465
UNIGROK_RESEARCH_PORT=7724

# Explainable model selection. Leave overrides blank for cached live-catalog
# capability routing (planning cold-starts on grok-4.5). Any nonblank override
# is an intentional hard pin and is named in each routing receipt.
UNIGROK_MODEL_DISCOVERY=1
UNIGROK_PLANNING_MODEL=
UNIGROK_CODING_MODEL=
UNIGROK_VISION_MODEL=
UNIGROK_RESEARCH_MODEL=
UNIGROK_ADVISOR_MARGIN=0.15

# Local-only git mutation gate.
ENABLE_GIT_WRITE=0

# Contributor-only commit-anchored engineering evidence. SQLite is authoritative;
# compact local Git Notes mirror only when ENABLE_GIT_WRITE=1.
UNIGROK_WORKSPACE_MEMORY=mirror

# Optional local-only Control Center restart helper. Keep disabled unless the
# server process has Docker access. When a root is set, it must be the exact
# checkout containing docker-compose.yml.
UNIGROK_ENABLE_CONTAINER_RESTART=0
UNIGROK_CONTAINER_RESTART_ROOT=

# HTTP request/resource bounds (override only for a deliberate deployment).
UNIGROK_MAX_REQUEST_BODY_BYTES=2097152
UNIGROK_MAX_MESSAGES=100
UNIGROK_MAX_MESSAGE_CHARS=64000
UNIGROK_MAX_TOTAL_MESSAGE_CHARS=500000

# Local file and media input bounds
UNIGROK_MAX_LOCAL_FILE_CHARS=500000
UNIGROK_MAX_REMOTE_FILE_BYTES=500000
UNIGROK_MAX_UPLOAD_BYTES=20000000
UNIGROK_MAX_PROJECT_FILES=1000
UNIGROK_MAX_MEDIA_INPUT_BYTES=20000000

# Maximum idle time between chunks from the direct xAI streaming proxy.
UNIGROK_XAI_STREAM_IDLE_TIMEOUT_SEC=180

# Credential-plane preference for compatible, unpinned local requests.
# cli_first (default) uses the authenticated subscription plane when possible;
# API-only thinking, vision, research, and explicit API model pins still use API.
UNIGROK_PLANE_POLICY=cli_first

# ── Knowledge memory: optional xAI Collections mirror (facts) ────────────────
# Local SQLite stays the source of truth; the mirror is best-effort.
# BOTH collection mirrors (facts + task memories) additionally need a
# MANAGEMENT API key — created separately from the inference key in the
# xAI console (https://console.x.ai). Without it the mirrors stay off and
# `rag status` reports "Please provide a management API key."
XAI_MANAGEMENT_API_KEY=
# Advanced/optional organization-wide API billing comparison. Ordinary local
# telemetry does not need a team id or management key. This never includes
# SuperGrok subscription usage and is never merged into CLI telemetry.
UNIGROK_XAI_TEAM_ID=
UNIGROK_PROVIDER_USAGE=auto
UNIGROK_COLLECTIONS=0
UNIGROK_COLLECTION_NAME=unigrok-knowledge
UNIGROK_COLLECTIONS_TIMEOUT=15
# Facts injected into dynamic context (0 disables, capped at 10).
UNIGROK_KNOWLEDGE_TOP_K=3

# ── Task-memory RAG (semantic routing evidence, src/rag.py) ──────────────────
# Works out of the box with just XAI_API_KEY: routing evidence comes from
# the LOCAL task-memory FTS index (bm25 + recency + per-model success).
# The xAI collection mirror is an optional boost that additionally needs
# XAI_MANAGEMENT_API_KEY (see above); keyless setups never make cloud calls.
# Rollout ladder: off (default) -> mirror (sync task memories to a
# collection; no-op without the management key) -> shadow (compute semantic
# routing verdicts, never apply) -> active (apply guarded verdicts on
# borderline prompts). Ops: `unigrok-mcp rag status` / `rag backfill --dry-run`.
UNIGROK_TASK_RAG=off
UNIGROK_TASK_RAG_COLLECTION=unigrok-task-memories-v2
UNIGROK_TASK_RAG_TIMEOUT=2.0
UNIGROK_TASK_RAG_TOP_K=5
UNIGROK_TASK_RAG_MARGIN=0.15
UNIGROK_TASK_RAG_MIN_EVIDENCE=3
UNIGROK_TASK_RAG_HALF_LIFE_HOURS=168
UNIGROK_TASK_RAG_FUSION_LOCAL_WEIGHT=0.65
UNIGROK_TASK_RAG_FUSION_REMOTE_WEIGHT=0.35

# ── Shadow semantic evals (src/semantic_evals.py) ────────────────────────────
# OBSERVATIONAL ONLY: a deterministic sample of live turns is graded by a
# cheap LLM judge (correctness / tool_efficiency / safety, 1-5) and the scores
# ride the telemetry metadata envelope for /metrics and grok_mcp_status.
# Routing NEVER consumes these scores, and judge calls never write
# circuit-breaker state. Judge calls are real paid API calls: each in-flight
# call reserves MAX_COST_PER_CALL against the daily budget (so concurrency
# cannot overrun the cap), and the accumulator is floored at the durable
# telemetry record once per day so restarts cannot re-arm an exhausted budget.
# Rollout: off (default) -> shadow (sample + grade + record).
UNIGROK_SEMANTIC_EVALS=off
UNIGROK_SEMANTIC_EVALS_RATE=0.05
UNIGROK_SEMANTIC_EVALS_MODEL=
UNIGROK_SEMANTIC_EVALS_TIMEOUT=45
UNIGROK_SEMANTIC_EVALS_MAX_CONCURRENT=2
UNIGROK_SEMANTIC_EVALS_DAILY_BUDGET_USD=1.00
UNIGROK_SEMANTIC_EVALS_MAX_COST_PER_CALL=0.02

# ── History compaction (structured state folding) ────────────────────────────
# Oversized session history is folded into a schema-enforced state entry
# (goal / constraints / dead ends / active files); prose summarization is the
# same-call fallback. Trigger: min(flat threshold, ratio * model context).
# UNIGROK_COMPACT_FOLD=0 forces the legacy prose-only path.
UNIGROK_COMPACT_THRESHOLD_TOKENS=24000
UNIGROK_COMPACT_CONTEXT_RATIO=0.5
UNIGROK_COMPACT_FOLD=1

# ── Swarm code optimizer (src/swarm/, contributor mode only) ─────────────────
# Bounded search over rewrites of ONE focus function, evaluated by YOUR tests
# (feasibility oracle) + benchmark; presents a Pareto front (latency / memory /
# diff size) for human apply. Generation is strictly pinned to the $0 CLI
# subscription plane and never crosses to metered API fallback. Rollout: off
# (default) -> dry_run (search + score, never apply) -> active
# (apply_swarm_winner enabled). Unknown value warns once.
UNIGROK_SWARM=off
# Explicit acknowledgement for the manual/nightly golden-target sweep. Even
# with a $0 metered receipt, it consumes real CLI subscription quota and time.
UNIGROK_SWARM_EVALS_LIVE=0
UNIGROK_SWARM_MAX_GENERATIONS=6
UNIGROK_SWARM_POPULATION=4
UNIGROK_SWARM_MAX_CONCURRENT_GEN=2
UNIGROK_SWARM_MAX_CONCURRENT_TASKS=1
UNIGROK_SWARM_EVAL_TIMEOUT=120
UNIGROK_SWARM_STAGE_BUDGET_FRACTION=0.5
UNIGROK_SWARM_BENCH_REPEATS=5
UNIGROK_SWARM_DEFAULT_BUDGET_USD=2.00
UNIGROK_SWARM_MAX_BUDGET_USD=10.00
UNIGROK_SWARM_MAX_COPY_MB=500
UNIGROK_SWARM_CHILD_MEM_MB=2048
# $0 ruff F821/F823 static gate between compile() and the sandbox stages
# (baseline-relative, correctness-only rules, no-ops if ruff is unavailable).
UNIGROK_SWARM_RUFF_FILTER=1
