# Local MCP port. Maintainers can override this when testing beside another UniGrok.
UNIGROK_PORT=4765

# Shared public harness controls.
UNIGROK_BUILD_TIMEOUT=120
UNIGROK_API_TIMEOUT=120
# Long-running autonomy + mission v2. Docker compose defaults these on for live.
UNIGROK_AUTONOMY=true
UNIGROK_MISSION_V2=true
UNIGROK_MISSION_ENVELOPE_VERSION=1
# A0′/A0: task-class assign + literal exact-match CommitDone.
UNIGROK_TASK_CLASS=true
UNIGROK_VERIFY_LITERAL=true
# Per-turn context pack prune + prefrontal condenser (off|cpu|hive).
# cpu: inventory → persona votes → lead merge → ≤2 PFC hive loops → bottom summary.
# Docker live default: cpu.
UNIGROK_CONTEXT_PACK=cpu
# Cap concurrent xAI SDK worker threads for metered generation/mutations.
# UNIGROK_API_MAX_INFLIGHT=4
# Separate smaller pool for file/catalog reads so slow list_files cannot HOL-block
# generation (B1). Default 2.
# UNIGROK_API_MAX_FILE_INFLIGHT=2
# Slow file/media deadlines (native SDK timeout is 2s under these await budgets).
# UNIGROK_FILE_LIST_TIMEOUT=120
# UNIGROK_FILE_IO_TIMEOUT=60
# UNIGROK_MEDIA_TIMEOUT=300
# Hard cap for xai_get_file_content downloads (checked via metadata before download).
# UNIGROK_FILE_CONTENT_MAX_BYTES=2000000
UNIGROK_CATALOG_TTL=60
UNIGROK_MAX_WORKSPACE_CONTEXT_CHARS=100000
UNIGROK_ENABLE_METERED_API=true

# Optional API default. When unset, UniGrok uses the first model returned by the live
# xAI language-model catalog. This is a preference, never a model allowlist.
# UNIGROK_API_MODEL=

# Optional metered xAI developer API plane. Keep this only in the server's ignored
# .env file; never add it to IDE MCP JSON.
# XAI_API_KEY=


# The Docker service creates a persistent OAuth volume and uses this in-container path.
UNIGROK_AUTH_PATH=/home/appuser/.grok/auth.json
