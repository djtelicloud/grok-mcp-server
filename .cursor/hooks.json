{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-unigrok-env.py",
        "timeout": 5
      }
    ],
    "beforeMCPExecution": [
      {
        "command": ".cursor/hooks/before-unigrok-agent.py",
